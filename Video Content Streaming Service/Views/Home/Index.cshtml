@model IEnumerable<Video_Content_Streaming_Service.ViewModels.VideoViewModel>

@{
    ViewData["Title"] = "Browse";
}

<style>
    .hero-banner {
        height: 70vh;
        background: linear-gradient(to bottom, rgba(20,20,20,0) 0%, rgba(20,20,20,1) 100%), url('https://images.unsplash.com/photo-1616469829581-73993eb86b02?q=80&w=2070') no-repeat center center;
        background-size: cover;
        display: flex;
        align-items: center;
        margin-top: -100px;
        padding-top: 100px;
    }

    .hero-content {
        max-width: 600px;
        padding-left: 50px;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 900;
        margin-bottom: 1rem;
    }

    .hero-description {
        font-size: 1.2rem;
        color: #e5e5e5;
        margin-bottom: 2rem;
    }

    .video-card {
        background: transparent;
        border: none;
        transition: transform 0.3s ease;
        cursor: pointer;
    }

        .video-card:hover {
            transform: scale(1.05);
            z-index: 10;
        }

    .video-thumbnail {
        border-radius: 4px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }

    .card-title {
        font-size: 0.9rem;
        margin-top: 8px;
        font-weight: 600;
        color: white;
    }
</style>

<div class="hero-banner">
    <div class="hero-content">
        <h1 class="hero-title">Unlimited Stories.</h1>
        <p class="hero-description">
            Experience high-definition streaming like never before.
            Upload your own content, share with the community, and discover
            the latest trending videos in our global library.
        </p>
        <div class="d-flex">
            <a asp-controller="Video" asp-action="Create" class="btn btn-light btn-lg fw-bold me-2 px-4">
                <i class="bi bi-play-fill"></i> Get Started
            </a>
            <button class="btn btn-secondary btn-lg fw-bold px-4 bg-opacity-50">
                <i class="bi bi-info-circle"></i> More Info
            </button>
        </div>
    </div>
</div>

<div class="container-fluid px-5">
    <h4 class="text-white mb-4 fw-bold">Trending Now</h4>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 row-cols-xl-6 g-3">
        @if (Model != null && Model.Any())
        {
            @foreach (var video in Model)
            {
                <div class="col">
                    <div class="card video-card">
                        <a asp-controller="Video" asp-action="Details" asp-route-id="@video.VideoId">
                            <div class="ratio ratio-16x9">
                                <video src="@video.VideoUrl" class="video-thumbnail object-fit-cover" muted onmouseover="this.play()" onmouseout="this.pause(); this.currentTime=0;"></video>
                            </div>
                        </a>
                        <div class="card-body p-0">
                            <p class="card-title text-truncate">@video.Title</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted" style="font-size: 0.75rem;">@video.UploaderName</small>
                                <span class="badge bg-secondary opacity-75" style="font-size: 0.6rem;">HD</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border border-secondary border-dashed rounded mt-4">
            <h5 class="text-muted">The library is currently empty.</h5>
            <p class="text-muted small">Be the first to contribute by clicking the 'Add Video' button above.</p>
        </div>
    }
</div>