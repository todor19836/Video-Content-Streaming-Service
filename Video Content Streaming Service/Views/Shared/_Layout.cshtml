<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StreamPro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body {
            background-color: #141414;
            color: white;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        .navbar {
            background-color: rgba(0, 0, 0, 0.9) !important;
            border-bottom: 1px solid #333;
        }

        .navbar-brand {
            font-weight: 800;
            color: #E50914 !important;
            font-size: 1.5rem;
            letter-spacing: -1px;
        }

        .nav-link {
            color: #e5e5e5 !important;
            transition: color 0.3s;
        }

            .nav-link:hover {
                color: #b3b3b3 !important;
            }

        .btn-upload {
            background-color: #E50914;
            color: white;
            border-radius: 4px;
            font-weight: bold;
            border: none;
            padding: 0.5rem 1.2rem;
        }

            .btn-upload:hover {
                background-color: #f6121d;
                color: white;
            }

        footer {
            border-top: 1px solid #333;
            color: #808080;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm mb-3 sticky-top">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">STREAMPRO</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Movies</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">TV Shows</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">My List</a></li>
                    </ul>
                    <div class="d-flex align-items-center">
                        <a asp-controller="Video" asp-action="Create" class="btn btn-upload me-3">
                            <i class="bi bi-plus-lg me-1"></i> ADD VIDEO
                        </a>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="py-4 mt-5">
        <div class="container text-center">
            <p>&copy; 2026 - StreamPro Content Service. High Fidelity Streaming Experience.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>